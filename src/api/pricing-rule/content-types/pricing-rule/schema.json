{
  "kind": "collectionType",
  "collectionName": "pricing_rules",
  "info": {
    "singularName": "pricing-rule",
    "pluralName": "pricing-rules",
    "displayName": "Pricing Rule"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "formula": {
      "type": "json",
      "required": true
    },
    "product_type": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "curtain",
        "blind",
        "cushion"
      ]
    },
    "fabrics": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::fabric.fabric",
      "mappedBy": "pricing_rules"
    }
  }
}
